# Local data paths
DATA_ROOT=data/raw
MANIFEST_PATH=data/raw/manifest.jsonl
PROCESSED_DIR=data/processed
EXPORT_DIR=data/exports

# Pipeline settings
DATASET_VERSION=v1.0
QUALITY_RULES_PATH=configs/quality_rules.yaml
USE_CLIP=false
CLIP_BATCH_SIZE=16

# Optional model cache for local CLIP runs
MODEL_CACHE_DIR=data/models/huggingface
